MEMBER(double, x, N*DIM)
MEMBER(double, v, N*DIM)
MEMBER(double, r, N)
MEMBER(double, rsq, N)
MEMBER(double, invr, N)
MEMBER(double, a, N*DIM)
MEMBER(double, f, N*DIM)
MEMBER(double, k, N)
MEMBER(double, m, N)
MEMBER(double, sqrtm, N)
MEMBER(double, invm, N)

MEMBER(double, angv, N*DIM) /* angular velocity */
MEMBER(double, anga, N*DIM) /* angular accelartion */
MEMBER(double, moi, N) /* moment of intertia */
MEMBER(double, invmoi, N)
MEMBER(double, mom, N*DIM) /* torque */

MEMBER(double, etaconst, N)
MEMBER(double, g, DIM)

MEMBER(int, isActive, N) /* flag if particle is OoB */ 

/* ======== tangential force related =========*/
/* history of delta tangent */
MEMBER(double, deltHisx, N*MAX_NEI) 
MEMBER(double, deltHisy, N*MAX_NEI)
MEMBER(double, deltHisz, N*MAX_NEI)

MEMBER(double, deltHisxWall, N*MAX_NEI)
MEMBER(double, deltHisyWall, N*MAX_NEI)
MEMBER(double, deltHiszWall, N*MAX_NEI)

MEMBER(int, indHis, N*MAX_NEI) /* Index of collided particles */ 
MEMBER(int, indHisWall, N*MAX_NEI) /* Index of collided particles */ 
MEMBER(int, indHisWallNow, N*MAX_NEI) /* Index of collided walls in the current step*/ 

MEMBER(int, indHisVorENow, N*MAX_NEI) /* number of contact with edge or vertex*/

MEMBER(int, isContact, N*MAX_NEI) /* flag if a particle has contacted with the neighbor in history*/ 
MEMBER(int, isContactWall, N*MAX_NEI)

             
MEMBER(int, numCont, N) /* number of contact */
MEMBER(int, numContWall, N) /* number of contact with walls */

MEMBER(int, cellId, N)
MEMBER(int, cellx, N*DIM) //coordinate index in structured cell


MEMBER(int, pId, N)
MEMBER(uint32_t, mortonKey, N)
MEMBER(int, mortonOrder, N)

MEMBER(uint32_t, tmpMortonKey, N)
MEMBER(int, tmpMortonOrder, N)


/* ========== verlet list related ========= */
MEMBER(double, refx, N)
MEMBER(double, refy, N)
MEMBER(double, refz, N) 
MEMBER(int, neiList, N*DIM) /* neighbor list */
MEMBER(int, numNei, N) /* neighbor list */
MEMBER(int, neiListWall, N*DIM) /* neighbor list */
MEMBER(int, numNeiWall, N) /* neighbor list */
